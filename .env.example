# ─── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here        # server-only, never NEXT_PUBLIC_

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# CRITICAL: never prefix with NEXT_PUBLIC_ — must remain server-only
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-secret-key-here              # use sk_live_ in production
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here
STRIPE_PRICE_PRO_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_PRO_ANNUAL=price_your-annual-price-id
STRIPE_PRICE_LIFETIME=price_your-lifetime-price-id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000                    # use https://yourdomain.com in production

# ─── PostHog (optional but recommended) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Google Ads / Google Tag (optional) ───────────────────────────────────────
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-1234567890

# ─── Sentry (optional but recommended) ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
